{
  "name": "alter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "ethers": "6.13.1"
  },
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",
    "dev:api": "npm run dev -w @alter/api",
    "dev:web": "npm run dev -w @alter/web",
    "build": "npm run build --workspaces --if-present",
    "contracts:compile": "npm run compile -w @alter/contracts",
    "contracts:deploy": "npm run deploy -w @alter/contracts",
    "check:0g": "npm run check:0g -w @alter/api",
    "resolve:ens": "npm run resolve:ens -w @alter/api --",
    "clear-agents": "npm run clear-agents -w @alter/api"
  }
}
