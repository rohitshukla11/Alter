# Copy to .env at repo root:  cp .env.example .env
# API loads this file from the monorepo root (and optionally apps/api/.env).

# --- API ---
PORT=4000
HOST=0.0.0.0
JWT_SECRET=change-me-to-a-long-random-string
PUBLIC_API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
DATA_DIR=./data

# --- Discovery & compute (optional upgrade paths) ---
# DISCOVERY_MODE=local | ens | hybrid (default local). hybrid merges file registry + 0G manifest / ENS index.
# DISCOVERY_MODE=local
# 0G root of alter-agent-index JSON (legacy counselr- / twinnet-agent-index still readable; updated when minting if set or ENS_INDEX_NAME is set).
# AGENT_INDEX_ROOT=
# Sepolia ENS name controlled by ENS_OPERATOR_PRIVATE_KEY; twinn.manifest = latest AGENT_INDEX_ROOT hash.
# ENS_INDEX_NAME=
# Inference fallback chain: 0g,mock,openai — requires OPENAI_API_KEY for openai.
# If true, legacy (non-OpenClaw) turns use ONLY 0G Compute — no mock/OpenAI fallback.
# STRICT_0G_MODE=false
# COMPUTE_PROVIDERS=0g,mock
# COMPUTE_MOCK_RESPONSE=[mock]
# OPENAI_API_KEY=
# PAYMENT_MODE=off | mock

# Reflection: re-upload evolved personality every N successful turns (0 = off).
# REFLECTION_EVERY_N=0

# --- World ID (https://developer.worldcoin.org) ---
WLD_RP_ID=
WLD_APP_ID=
WLD_SIGNING_KEY_HEX=
WLD_ACTION=alter-verify
WLD_ENVIRONMENT=production

# --- 0G Galileo testnet (chainId 16602) ---
# Fund these addresses from https://faucet.0g.ai (native 0G for gas + ledger).
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
# Optional explorer base (default: Galileo 0G Scan)
# ZG_EXPLORER_URL=https://chainscan-galileo.0g.ai
# Signs storage uploads (agent config + conversation blobs). Must hold 0G on Galileo.
ZG_STORAGE_PRIVATE_KEY=
# Signs compute ledger ops; broker uses this wallet for inference. Same or different from storage.
ZG_COMPUTE_PRIVATE_KEY=
# Optional: 0x address of a specific inference provider from listService(); leave empty to use the first provider.
# ZG_INFERENCE_PROVIDER=
#
# Optional: OpenAI-compatible 0G inference proxy (e.g. Integrate Network). When BOTH are set, OpenClaw and
# infer0GChat use POST {ZG_COMPUTE_PROXY_URL}/chat/completions with Authorization: Bearer {key}
# (same pattern as the OpenAI Node SDK baseURL + apiKey). Skips the 0G serving broker for chat only.
# ZG_COMPUTE_PROXY_URL=https://compute-network-6.integratenetwork.work/v1/proxy
# ZG_COMPUTE_PROXY_API_KEY=app-sk-...
# ZG_COMPUTE_PROXY_MODEL=qwen/qwen-2.5-7b-instruct

# --- TwinAgent iNFT on 0G (deploy via packages/contracts) ---
# `npm run contracts:deploy` uses DEPLOYER_PRIVATE_KEY, or falls back to INFT_OWNER_PRIVATE_KEY.
# DEPLOYER_PRIVATE_KEY=
INFT_CONTRACT_ADDRESS=
INFT_OWNER_PRIVATE_KEY=
# Optional: override default tokenURI pattern for new mints. Use {root} or {metadataRoot} as 0x-prefixed hash placeholder.
# NFT_TOKEN_URI_TEMPLATE=
# Default true: POST /agents writes registry.json so Marketplace lists new agents without waiting for manifest/chain index.
# Set false only if you rely purely on ENS manifest + chain discovery.
# PERSIST_AGENTS_LOCALLY=true

# --- Sepolia ENS (resolution + optional text records) ---
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
# If set and the key controls the agent ENS name’s resolver, API writes twinn.* text records.
# ENS_OPERATOR_PRIVATE_KEY=

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WLD_APP_ID=

# --- Vercel (set in dashboard for apps/web deploy) ---
# Root Directory: apps/web  |  Install uses monorepo: see apps/web/vercel.json
# NEXT_PUBLIC_API_URL=https://your-api-host.example.com
# NEXT_PUBLIC_WLD_APP_ID=app_...
# See VERCEL.md for CORS, World ID RP ID, and API hosting.
